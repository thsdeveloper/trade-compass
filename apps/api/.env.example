# BRAPI API - https://brapi.dev
BRAPI_TOKEN=your_brapi_token

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Frontend URL for password recovery redirects
FRONTEND_URL=http://localhost:3000

# Deep link de retorno do OAuth no app mobile
# Dev (Expo Go): exp://SEU_IP_LOCAL:8081/--/auth | Producao (app buildado): tradecompass://auth
MOBILE_REDIRECT_URL=

# OpenAI (importacao de extrato com IA)
OPENAI_API_KEY=sk-proj-xxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Pluggy (Open Finance - importacao de dados bancarios)
# Credenciais da aplicacao no dashboard da Pluggy (SO no servidor, nunca no app).
PLUGGY_CLIENT_ID=your_pluggy_client_id
PLUGGY_CLIENT_SECRET=your_pluggy_client_secret
# URL publica do webhook (Fase 1). Ex: https://trade-compass-api.fly.dev/webhooks/pluggy
PLUGGY_WEBHOOK_URL=
# Segredo estatico validado no header do webhook (Pluggy nao assina com HMAC).
PLUGGY_WEBHOOK_SECRET=

# Algolia Search Configuration
ALGOLIA_APP_ID=your_algolia_app_id
ALGOLIA_ADMIN_KEY=your_algolia_admin_key
ALGOLIA_SEARCH_ONLY_KEY=your_algolia_search_only_key

# Resend Email Configuration
RESEND_API_KEY=re_xxxxxxxxxxxx
# For development, leave EMAIL_FROM empty to use Resend's test domain (onboarding@resend.dev)
# For production, use your verified domain: Trade Compass <noreply@tradecompass.app>
EMAIL_FROM=
EMAIL_REPLY_TO=
